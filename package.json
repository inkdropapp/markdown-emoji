    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@inkdropapp/types": "^0.0.9",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "remark-gemoji": "^8.0.0",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3"
  },
  "engines": {
    "inkdrop": "^6.0.0"
  }
