{
  "name": "markdown-emoji",
  "version": "1.1.1",
  "description": "Add emoji syntax support to Markdown",
  "keywords": [
    "emoji",
    "gemoji",
    "inkdrop",
    "markdown"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/inkdropapp/inkdrop-markdown-emoji.git"
  },
  "main": "./lib/index.js",
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown",
    "format": "oxfmt",
    "lint": "oxlint",
